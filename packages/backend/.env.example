HAMB_APP_NAME=hydroponic-backend
HAMB_APP_ENV=dev

HAMB_SERVER_HOST=0.0.0.0
HAMB_SERVER_PORT=8080

HAMB_AUTH_JWT_SECRET=change-me
HAMB_AUTH_TOKEN_EXPIRE_SECS=7200

HAMB_MYSQL_HOST=127.0.0.1
HAMB_MYSQL_PORT=3307
HAMB_MYSQL_USER=root
HAMB_MYSQL_PASSWORD=root
HAMB_MYSQL_DATABASE=hydroponic
HAMB_MYSQL_PARAMS=charset=utf8mb4&parseTime=True&loc=Local

HAMB_INFLUX_URL=http://127.0.0.1:8086
HAMB_INFLUX_TOKEN=your-token
HAMB_INFLUX_ORG=hydroponic
HAMB_INFLUX_BUCKET=telemetry

HAMB_MQTT_BROKER=tcp://127.0.0.1:1883
HAMB_MQTT_USERNAME=emqx
HAMB_MQTT_PASSWORD=public
HAMB_MQTT_CLIENT_ID=hamb-backend

HAMB_LOG_LEVEL=info
